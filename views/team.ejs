    <title>Our Team | STUMDieY</title>
    <style>
:root {
    --primary-color: #31b6bf;
    --secondary-color: #e7e7f1;
    --text-dark: #333333;
    --text-light: #767268;
    --extra-light: #f3f4f6;
    --white: #ffffff;
    --shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    --transition: all 0.3s ease;
    --card-bg: #ffffff;
    --nav-bg: #282c34;
    --accent-color: #61dafb;
}

[data-theme="dark"] {
    --primary-color: #4fd1c5;
    --secondary-color: #2d3748;
    --text-dark: #f7fafc;
    --text-light: #cbd5e0;
    --extra-light: #1a202c;
    --card-bg: #2d3748;
    --nav-bg: #1a202c;
    --accent-color: #81e6d9;
    --shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
}

* {
    padding: 0;
    margin: 0;
    box-sizing: border-box;
}

body {
    font-family: "Open Sans", sans-serif;
    background-color: var(--secondary-color);
    color: var(--text-dark);
    transition: var(--transition);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

/* Navbar Styles */
.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: var(--nav-bg);
    padding: 1rem 2rem;
    color: var(--white);
    position: fixed;
    width: 100%;
    top: 0;
    z-index: 1000;
    box-shadow: var(--shadow);
    transition: var(--transition);
}

.brand-title {
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--accent-color);
    transition: var(--transition);
}

.navbar-links {
    display: flex;
}

.navbar-links ul {
    display: flex;
    list-style: none;
    gap: 1.5rem;
}

.navbar-links a {
    color: var(--white);
    text-decoration: none;
    font-size: 1.1rem;
    position: relative;
    transition: var(--transition);
    padding: 0.5rem 0;
}

.navbar-links a::after {
    content: "";
    position: absolute;
    width: 0;
    height: 2px;
    bottom: 0;
    left: 0;
    background-color: var(--accent-color);
    transition: var(--transition);
}

.navbar-links a:hover::after {
    width: 100%;
}

.navbar-links a:hover {
    color: var(--accent-color);
}

.toggle-button {
    display: none;
    font-size: 1.5rem;
    color: var(--white);
    background: none;
    border: none;
    cursor: pointer;
}

/* Theme Toggle Button */
.theme-toggle {
    background: none;
    border: none;
    color: var(--white);
    font-size: 1.5rem;
    cursor: pointer;
    margin-left: 1.5rem;
    transition: var(--transition);
}

.theme-toggle:hover {
    transform: rotate(30deg);
}

/* Main Content */
.main-content {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: stretch; /* Stretch items to equal height */
    gap: 2rem;
    padding: 8rem 2rem 2rem; /* Increased top padding */
    flex-wrap: wrap; /* Allow wrapping on smaller screens */
}

/* Profile Card */
.profile__card {
    display: flex;
    align-items: center;
    max-width: 600px; /* Reduced max-width */
    width: 100%;
    padding: 2rem; /* Slightly reduced padding */
    text-align: left;
    border-radius: 15px;
    background-color: var(--card-bg);
    box-shadow: var(--shadow);
    transition: var(--transition);
    position: relative;
    overflow: hidden;
    margin: 1rem;
}

.profile__card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 8px;
    background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
}

.profile__card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
}

.profile__card .profile__image {
    margin-right: 2rem;
}

.profile__card .profile__image img {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--primary-color);
    margin-bottom: 0;
    transition: var(--transition);
}

.profile__card:hover img {
    transform: scale(1.05);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
}

.name {
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 0.5rem;
}

.designation {
    font-size: 0.9rem;
    color: var(--text-light);
    margin-bottom: 1.5rem;
    font-weight: 500;
}

.profile__details {
    padding: 1.5rem 0;
    display: flex;
    justify-content: center;
    gap: 2rem;
}

.profile__details .col {
    text-align: center;
}

.profile__details p {
    font-size: 0.9rem;
    color: var(--text-light);
    margin-bottom: 0.3rem;
}

.profile__details h4 {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--primary-color);
}

.about {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.6;
    margin-bottom: 2rem;
}

.social__icons {
    display: flex;
    justify-content: center;
    gap: 1.2rem;
    margin-bottom: 2rem;
}

.icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    font-size: 1.2rem;
    transition: var(--transition);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
}

.icon:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 15px rgba(0, 0, 0, 0.2);
}

.ig {
    background: linear-gradient(45deg, #405de6, #5851db, #833ab4, #c13584, #e1306c, #fd1d1d);
}

.threads {
    background: linear-gradient(45deg, #000000, #333333, #666666);
}

.github {
    background: linear-gradient(45deg, #333333, #6e5494);
}

.no {
    display: inline-block;
    padding: 0.8rem 2rem;
    font-size: 0.95rem;
    color: var(--primary-color);
    background-color: transparent;
    border: 2px solid var(--primary-color);
    border-radius: 50px;
    font-weight: 600;
    transition: var(--transition);
    text-decoration: none;
    cursor: pointer;
}

.no:hover {
    color: var(--white);
    background-color: var(--primary-color);
    box-shadow: 0 5px 15px rgba(49, 182, 191, 0.4);
}

/* Footer */
.footer {
    text-align: center;
    padding: 1.5rem;
    background-color: var(--nav-bg);
    color: var(--white);
    font-size: 0.9rem;
}

/* Responsive Styles */
@media (max-width: 992px) {
    .navbar-links ul {
        gap: 1rem;
    }
}

@media (max-width: 768px) {
    .navbar {
        flex-direction: column;
        align-items: flex-start;
        padding: 1rem;
    }
    
    .navbar-header {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .navbar-links {
        width: 100%;
        display: none;
    }
    
    .navbar-links.active {
        display: flex;
    }
    
    .navbar-links ul {
        flex-direction: column;
        width: 100%;
        gap: 0.5rem;
        padding: 1rem 0;
    }
    
    .toggle-button {
        display: block;
    }
    
    .main-content {
        padding-top: 8rem;
    }
}

@media (max-width: 480px) {
    .profile__card {
        padding: 2rem 1.5rem;
    }
    
    .profile__details {
        flex-direction: column;
        gap: 1rem;
    }
}
    </style>
</head>
